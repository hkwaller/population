# Copy to .env.local and fill in. Provision fresh projects (do NOT reuse ish's).

# --- Liveblocks (realtime multiplayer) --- https://liveblocks.io
LIVEBLOCKS_SECRET_KEY=sk_dev_xxx

# --- Supabase (question bank + game stats) --- https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
# Service role key - used ONLY by scripts/migrate-questions.ts to seed. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=xxx

# --- Clerk (auth; anonymous guests work without sign-in) --- https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Local dev flag ---
DEVELOPMENT=true

# --- REST Countries v5 (build-time only; regenerates lib/geo/countries.json) --- https://restcountries.com
RESTCOUNTRIES_API_KEY=rc_live_xxx

# --- Adsterra (ads) --- https://adsterra.com
# Banner: the "Key" from a 468x60 Banner ad unit. Popunder: the full invoke.js src URL.
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSTERRA_POPUNDER_SRC=//pl00000000.topcreativeformat.com/xx/xx/xx/xxxxxxxx.js

# --- Stripe (ad-free subscription) --- https://dashboard.stripe.com
# Use test keys (sk_test_… / whsec_… from `stripe listen`) in dev; live keys in prod.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs for the "Population Ad-Free" product (create per-mode in each Stripe account).
STRIPE_PRICE_DAY=price_xxx    # one-time 24h day pass
STRIPE_PRICE_MONTH=price_xxx  # recurring monthly
STRIPE_PRICE_YEAR=price_xxx   # recurring yearly
# Optional: used for Checkout return URLs when the Origin header is unavailable.
NEXT_PUBLIC_APP_URL=http://localhost:3000
